{
  "name": "brand-x-intelligence-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "python3 scripts/run_daily.py",
    "refresh": "python3 scripts/run_fermentation_refresh.py",
    "check": "python3 scripts/check_dashboard_data.py",
    "verify:data": "python3 scripts/verify_data.py",
    "verify:browser": "node scripts/verify_dashboard.cjs",
    "qa:local-browser": "bash scripts/local_browser_qa.sh",
    "local:setup": "bash scripts/macos/setup_local.sh",
    "local:setup:check": "bash scripts/macos/check_local.sh",
    "local:language:check": "bash scripts/macos/check_language_processing.sh",
    "local:translation:check": "bash scripts/macos/check_language_processing.sh",
    "local:daily:preview": "bash scripts/macos/run_local_daily_preview.sh",
    "local:daily:preview:resume": "BRAND_RADAR_RESUME_FROM_CHECKPOINT=1 bash scripts/macos/run_local_daily_preview.sh",
    "local:daily": "bash scripts/macos/run_local_daily.sh",
    "local:daily:resume": "BRAND_RADAR_RESUME_FROM_CHECKPOINT=1 bash scripts/macos/run_local_daily.sh",
    "local:daily:install": "bash scripts/macos/install_daily_launchd.sh",
    "local:daily:uninstall": "bash scripts/macos/uninstall_daily_launchd.sh",
    "local:daily:status": "bash scripts/macos/daily_status.sh",
    "serve": "python3 -m http.server 4173 --directory public"
  }
}
